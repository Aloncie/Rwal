{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-release",
      "displayName": "Windows Release (Ninja)",
      "description": "Windows CLI build with Qt6 via QTDIR, vcpkg for curl/json",
      "generator": "Ninja",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "BUILD_TUI": "OFF",
        "RWAL_FORCE_DE": "Windows",
        "CMAKE_PREFIX_PATH": "$env{QTDIR}"
      }
    },
    {
      "name": "linux-release",
      "displayName": "Linux Release (Ninja)",
      "description": "Linux TUI+CLI build with Qt6 via QTDIR",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_PREFIX_PATH": "$env{QTDIR}"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-release",
      "configurePreset": "windows-release",
      "configuration": "Release"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-release",
      "configuration": "Release"
    }
  ]
}
